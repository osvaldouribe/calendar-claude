{
  "name": "cosmic-calendar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":        "next dev",
    "build":      "prisma generate && next build",
    "start":      "next start",
    "db:migrate": "prisma migrate deploy",
    "db:push":    "prisma db push",
    "db:seed":    "ts-node --project tsconfig.json prisma/seed.ts",
    "db:studio":  "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^1.0.0",
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "next": "^14.0.0",
    "next-auth": "^5.0.0-beta.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "resend": "^3.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.0.0",
    "postcss": "^8.0.0",
    "prisma": "^5.0.0",
    "tailwindcss": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.json prisma/seed.ts"
  }
